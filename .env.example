# Committed template. Copy the backend section into backend/.env and the
# NEXT_PUBLIC_* section into frontend/.env.local — both gitignored.
#   - backend/.env is auto-loaded by godotenv/autoload when `air` runs
#     (cwd = backend/); read via internal/config. Required vars panic on
#     startup if missing.
#   - frontend/.env.local is auto-loaded by Next.js from the frontend
#     project root; NEXT_PUBLIC_* is inlined into the client bundle at
#     build time.
#   - DATABASE_URL_DIRECT lives in backend/.env but is shell-only (goose
#     reads it from your environment, never from Config). Source the file
#     before running migrations, or use direnv.

# --- Database (Supabase) ---
# Both URLs point at Supabase's Direct Connection host. The split is
# role-and-lifecycle, not host. See CLAUDE.md §Database connection and
# stack.md §8 for the full rationale (short version: pgxpool is an
# in-process transaction pooler, so an external pooler is redundant
# and would break pgx prepared statements).
#
# DATABASE_URL: app runtime, read by config.Load() at boot, consumed by
#   pgxpool. Supabase dashboard → Project Settings → Database →
#   Connection string → "Direct connection":
#     postgres://postgres:<password>@db.<project-ref>.supabase.co:5432/postgres?sslmode=require
#   Both URLs use the `postgres` role for v1. Later we introduce a
#   `corellia_app` role that DATABASE_URL switches to (non-RLS-bypassing);
#   DATABASE_URL_DIRECT stays on `postgres`.
#
#   IPv4 fallback: if your local network can't reach the Direct host
#   over IPv6, swap DATABASE_URL for the Session Pooler form from the
#   same dashboard page (`*.pooler.supabase.com:5432`). Drop-in — no
#   code change. NEVER use Transaction Pooler (`:6543`) — breaks pgx.
#
# DATABASE_URL_DIRECT: migration-only, same Direct host, `postgres`
#   superuser role (needed for DDL on Supabase's `auth` schema triggers).
#   Read only by `goose` from the shell. NOT in config.Config — the Go
#   binary never sees superuser credentials.
DATABASE_URL=
DATABASE_URL_DIRECT=

# --- Supabase Auth ---
# The backend validates access tokens offline via Supabase's JWKS (ES256 /
# ECDSA P-256). The JWKS URL is derived from SUPABASE_URL automatically:
#   $SUPABASE_URL/auth/v1/.well-known/jwks.json
# No JWT secret is required — keys rotate server-side and the middleware
# refreshes the set hourly (and immediately on any unknown `kid`).
SUPABASE_URL=https://<project-ref>.supabase.co
# Frontend-bundled; safe for client exposure.
SUPABASE_ANON_KEY=

# --- Supabase (frontend-facing copies) ---
# These belong in frontend/.env.local, not backend/.env. Next.js only inlines
# NEXT_PUBLIC_*-prefixed vars into the client bundle at build time. Values
# must match their non-prefixed twins in backend/.env (the duplication is
# the intentional cost of the per-app env-file split).
NEXT_PUBLIC_SUPABASE_URL=https://<project-ref>.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# --- Fly.io ---
# Required by config.Config but not read by any code yet — placeholders are
# fine until FlyDeployTarget lands. `fly auth token` prints the token.
FLY_API_TOKEN=placeholder-until-fly-deploy-target-exists
FLY_ORG_SLUG=personal

# --- Backend server ---
PORT=8080
FRONTEND_ORIGIN=http://localhost:3000

# --- Frontend (populated when frontend/ scaffolds) ---
NEXT_PUBLIC_API_URL=http://localhost:8080
