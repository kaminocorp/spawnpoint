# Copy to .env at repo root and fill in real values. Do not commit .env.
# Loaded by both halves: Go backend reads via internal/config (required vars
# panic on startup); Next.js reads NEXT_PUBLIC_* at build time.

# --- Database (Supabase) ---
# Two URLs by design — see backend-scaffolding.md §6.
#
# DATABASE_URL: app connection, via Supabase Session Pooler (Supavisor).
#   Supabase dashboard → Project Settings → Database → Connection string →
#   "Session pooler" mode. Example:
#     postgres://postgres.<project-ref>:<password>@aws-0-<region>.pooler.supabase.com:5432/postgres?sslmode=require
#   Both URLs use the `postgres` role for v1. Later we introduce a
#   `corellia_app` role that DATABASE_URL switches to (non-RLS-bypassing).
#   DATABASE_URL_DIRECT stays on `postgres`.
#
# DATABASE_URL_DIRECT: migration-only, direct connection (bypasses pooler).
#   Dashboard → "Direct connection" string:
#     postgres://postgres:<password>@db.<project-ref>.supabase.co:5432/postgres?sslmode=require
#   Read only by `goose` from the shell. NOT in config.Config — the Go
#   binary never sees superuser credentials.
DATABASE_URL=
DATABASE_URL_DIRECT=

# --- Supabase Auth ---
SUPABASE_URL=https://<project-ref>.supabase.co
SUPABASE_JWT_SECRET=
# Frontend-bundled; safe for client exposure.
SUPABASE_ANON_KEY=

# --- Supabase (frontend-facing copies) ---
# Next.js only reads NEXT_PUBLIC_*-prefixed vars from .env(.local) into the
# client bundle. Mirror SUPABASE_URL and SUPABASE_ANON_KEY here so the same
# .env file feeds both halves. Values must match their non-prefixed twins.
NEXT_PUBLIC_SUPABASE_URL=https://<project-ref>.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# --- Fly.io ---
# Required by config.Config but not read by any code yet — placeholders are
# fine until FlyDeployTarget lands. `fly auth token` prints the token.
FLY_API_TOKEN=placeholder-until-fly-deploy-target-exists
FLY_ORG_SLUG=personal

# --- Backend server ---
PORT=8080
FRONTEND_ORIGIN=http://localhost:3000

# --- Frontend (populated when frontend/ scaffolds) ---
NEXT_PUBLIC_API_URL=http://localhost:8080
